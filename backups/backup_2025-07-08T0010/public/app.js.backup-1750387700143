                let found = data.jokes.find(j => normalize(j.title) === normalizedTitle);
                if (!found) {
                    // Try partial match
                    found = data.jokes.find(j => normalize(j.title).includes(normalizedTitle) || normalizedTitle.includes(normalize(j.title)));
                }
                if (found) {
