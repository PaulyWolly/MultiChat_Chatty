                const displayName = query.replace(/^youtube\s+search\s+/i, '')
                        .replace(/^youtube\s+/i, '')
                        .replace(/^search\s+/i, '')
                        .trim() || query;
    
                // Initialize cache keys and metadata
                const cacheKeys = [`yt_${normalizedQuery}_search_1`];
                const searchMetadata = {
                    searchType: 'search',
                    lastPageViewed: 1,
                    totalResults: 1
                };
    
                btn.disabled = true;
                btn.title = 'Saving...';
                try {
