+// Add YouTube cache manager
+const youtubeCacheManager = {
+    CACHE_PREFIX: 'yt_cache_',
+    MAX_AGE: 1000 * 60 * 60, // 1 hour cache
+
+    getCacheKey(query, type, pageToken) {
+        return `${this.CACHE_PREFIX}${query}-${type}-${pageToken || 'first'}`;
+    },
+
+    get(query, type, pageToken) {
+        const key = this.getCacheKey(query, type, pageToken);
+        const cached = localStorage.getItem(key);
+        if (!cached) return null;
+
+        const { data, timestamp } = JSON.parse(cached);
+        if (Date.now() - timestamp > this.MAX_AGE) {
+            localStorage.removeItem(key);
+            return null;
+        }
+        return data;
+    },
+
+    set(query, type, pageToken, data) {
+        const key = this.getCacheKey(query, type, pageToken);
+        const cacheEntry = {
+            data,
+            timestamp: Date.now()
+        };
+        localStorage.setItem(key, JSON.stringify(cacheEntry));
+    },
+
+    clear() {
+        Object.keys(localStorage)
+            .filter(key => key.startsWith(this.CACHE_PREFIX))
+            .forEach(key => localStorage.removeItem(key));
